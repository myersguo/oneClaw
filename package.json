{
  "name": "oneclaw-manager",
  "version": "1.0.0",
  "description": "Desktop management tool for OpenClaw AI Assistant",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared",
    "desktop"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\" \"npm run dev -w desktop\"",
    "dev:web": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:desktop": "npm run dev -w desktop",
    "build": "npm run build --workspaces",
    "build:binary": "./scripts/build-desktop.sh",
    "lint": "npm run lint --workspaces",
    "start": "node backend/dist/index.js",
    "postinstall": "cd desktop && npx electron-rebuild -f -w better-sqlite3"
  },
  "keywords": [
    "openclaw",
    "ai",
    "manager",
    "electron",
    "react",
    "nodejs"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "concurrently": "^8.2.2"
  }
}
