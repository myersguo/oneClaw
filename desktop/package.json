    "@types/node": "^24.10.1",
    "concurrently": "^8.2.2",
    "electron": "^33.4.11",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "better-sqlite3": "12.6.2",
    "bindings": "^1.5.0",
    "debug": "^4.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "file-uri-to-path": "1.0.0",
    "get-port": "5.1.1",
    "ms": "^2.1.3",
    "prebuild-install": "^7.1.1"
  }
