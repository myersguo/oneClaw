{
  "name": "@oneclaw/desktop",
  "version": "1.0.0",
  "description": "OneClaw Desktop Application",
  "author": "OneClaw Team",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently -k \"pnpm --filter frontend dev\" \"wait-on http://localhost:5175 && tsc && NODE_ENV=development electron .\"",
